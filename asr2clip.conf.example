# asr2clip configuration — uncomment and fill in one backend to start.
# Test with: asr2clip --test -b <name>   Switch at runtime: asr2clip -b <name>

## ── Audio input ───────────────────────────────────────────────────────────────
# Specify the input device by human-readable name, device index, or preference order.
# asr2clip automatically routes to the correct recorder backend (sounddevice or arecord).
#
# Single device (uses system default if device is unavailable):
#   audio_device: "Snowball"                  # Human-readable name (substring match)
#   audio_device: "auto"                      # System default input device
#   audio_device: 3                           # Device index from --list_devices output
#
# Preference order (tries first available device; falls back if USB device unplugged):
#   audio_device: "Snowball,Webcam,auto"     # Try Snowball, fall back to Webcam, then default
#   audio_device: [Snowball, Webcam, auto]   # YAML list syntax (optional alternative)
#
# Run `asr2clip --list_devices` to see available device names and indices.
#
# audio_device: "auto"                        # Use system default (recommended)

## ── Toggle-mode recorder ──────────────────────────────────────────────────────
# Controls which backend captures audio during --toggle mode.
#   auto        — sounddevice (cross-platform, always available); arecord as opt-in
#   sounddevice — Python/PortAudio recorder (works everywhere, already a dependency)
#   arecord     — direct ALSA recorder (Linux only, requires alsa-utils)
# recorder: auto

## ── Audio preprocessing (noise reduction) ────────────────────────────────────
# Options: none, noisereduce, pyrnnoise, deepfilter
#   none        — no preprocessing, zero latency, no extra dependencies
#   noisereduce — spectral subtraction; best for stationary noise (fan, AC)
#                 install: pip install asr2clip[noisereduce]
#   pyrnnoise   — Mozilla RNNoise GRU; best for non-stationary noise (babble)
#                 install: pip install asr2clip[pyrnnoise]
#   deepfilter  — DeepFilterNet3, best quality overall, medium CPU
#                 install: pip install asr2clip[deepfilter]
# Override at runtime: asr2clip -p deepfilter -i meeting.mp4
preprocessor_live: none                       # applied to live/toggle; consider noisereduce
preprocessor_file: none                       # applied to -i FILE; consider deepfilter

## ── ASR backends ──────────────────────────────────────────────────────────────
asr_backends:
  # openai:                                   # OpenAI Whisper API
  #   type: api
  #   api_base_url: "https://api.openai.com/v1/"
  #   api_key: "sk-..."
  #   model_name: "whisper-1"
  #   # language: en                          # ISO-639-1; omit to auto-detect
  # groq:                                     # Groq — fast, free tier available
  #   type: api
  #   api_base_url: "https://api.groq.com/openai/v1/"
  #   api_key: "YOUR_GROQ_KEY"
  #   model_name: "whisper-large-v3-turbo"
  # siliconflow:                              # SiliconFlow
  #   type: api
  #   api_base_url: "https://api.siliconflow.com/v1/"
  #   api_key: "YOUR_API_KEY"
  #   model_name: "FunAudioLLM/SenseVoiceSmall"
  # xinference:                               # xinference or other self-hosted endpoint
  #   type: api
  #   api_base_url: "http://localhost:9997/v1/"
  #   api_key: "any"                          # required field, value not checked
  #   model_name: "SenseVoiceSmall"
  # sonnx:                                    # local sherpa-onnx server (pip install asr2clip[vad])
  #   type: api
  #   api_base_url: "http://127.0.0.1:8000/v1/"
  #   model_name: "SenseVoiceSmall"
  # wcpp:                                     # whisper.cpp — build from source, fully offline
  #   type: whisper_cpp
  #   binary: ~/path/to/whisper.cpp/build/bin/whisper-cli
  #   model:  ~/path/to/whisper.cpp/models/ggml-large-v3-turbo-q8_0.bin
  #   # language: auto                        # 'auto' or ISO-639-1 (e.g. fi, en)
  #   # threads: 4

## Default ASR backend selection (override with -b NAME):
asr_backend_live: sonnx                       # backend for live/toggle/VAD recording
asr_backend_file: wcpp                        # backend for file transcription (-i FILE)

## ── Diarization ───────────────────────────────────────────────────────────────
## Speaker diarization via WhisperX. Requires: pip install asr2clip[diarize]
## Enable per run with -D / --diarize. Replaces the configured ASR backend.
## Output: "[HH:MM:SS] SPEAKER_NN: text" — name substitution is left to the caller.
# diarize_hf_token: "hf_..."                  # HuggingFace token for pyannote model download
#                                             # or set HF_TOKEN env var
# diarize_min_speakers: 2                     # optional hint to pyannote; omit for auto
# diarize_max_speakers: 6

## ── Post-processing (with AI models) ──────────────────────────────────────────
# Post-processors send the transcript to an AI model and return structured output.
# Enable a post-processor for a mode, or pass -P NAME per run.
# Requires postprocessor_backends and postprocessors sections below.

## Post-processor backends:
postprocessor_backends:                       # FIXME: Update this section based on your setup
  groq:                                       # Groq — fast, generous free tier
    type: openai_compat
    api_base_url: "https://api.groq.com/openai/v1/"
    api_key: "YOUR_GROQ_KEY"
    model: "llama-3.3-70b-versatile"
  ollama:                                     # Ollama — free, private, fully offline
    type: openai_compat
    api_base_url: "http://localhost:11434/v1/"
    api_key: "ollama"                         # Ollama ignores the key value
    model: "qwen3:14b"
#   anthropic:                                # Anthropic API (OpenAI-compatible endpoint)
#     type: openai_compat
#     api_base_url: "https://api.anthropic.com/v1/"
#     api_key_env: ANTHROPIC_API_KEY          # reads key from environment variable
#     model: "claude-haiku-4-5-20251001"
#   cc:                                       # Claude Code CLI — uses your CC subscription
#     type: claude_code                       # no api_key needed; uses active CC session
#     model: "claude-haiku-4-5-20251001"

## Prompt library — add as many prompts as you like.
# Each prompt is available via -P NAME or as the postprocessor_live/file default.
# Fields per prompt:
#   prompt:        system prompt text (required unless 'extends' is used)
#   extends:       inherit system prompt from another named prompt in this config
#   extra:         text appended after the inherited prompt (used with extends)
#   backend:       which postprocessor_backends entry to use (default: first defined)
#   model:         override the backend's default model for this prompt
#   template:      output template name from output_templates below (default: "default")
#   context_path:  list of file glob patterns; contents are injected into the LLM request
postprocessors:                               # FIXME: These are not commented out but you still need to adapt them for yourself to make them work
  solo-base:                                  # Note this is a "base" and is not intended to be used as a post-processor directly; The solo-enhance was devised as the minimal post-processor.
    backend: groq
    template: bare
    prompt: |
      You are a professional personal transcript scribe and memo writer.
      Attached is a transcript from a recording that should only contain your client's (= author/user) voice.
      Both the recording and the transcribing may have produced sub-standard quality which may make your work more demanding.
      Overcome any possible mistakes in the transcript and attempt to understand the true intent of the speaker.

  solo-enhance:
    extends: solo-base
    extra: |
      The content may be intended to constitute a message, an email, a command, a personal diary or note entry, or an unstructured thinking-aloud segment, or something else.
      Produce an enhanced transcript that honors the author's original choice of words, structures and flow but fix misspellings and grammatical and transcription mistakes, reduce unnecessary words and repetition and otherwise improve the quality and legibility of the transcript.
      Output the enhanced transcript without any frontmatter or leading "meta" notes.
      Any significant interpretation uncertainties that have substantive impact on the information content can however be noted at the end after a separator line '\n---\n\n'.

  solo-restructure:
    extends: solo-base
    context_path:
      - "~/.asr2clip/context/personal.md"     # include personal context info to improve reasoning
    extra: |
      The content may be from a long unstructured dictation or thinking-aloud session for some purpose (which may be deducible from the transcript itself).
      Produce a concise, structured memo that maximizes legibility and usefulness.
#      Write in the main language that was used in the transcript.
      The following provides a template. Omit sections that would have no clear content.

      # YYYY-MM-DD HH:SS Solo Notes on <Topic in Title Case>
      Tags: memo, <3-10 tags relevant to the content of the meeting>

      ## Summary
      <2-5 sentences describing the purpose, nature and content of the meeting overall>

      ## Key points
      <Bulleted list; Important to get all essential discussion topics and contributions covered; Chronological flow is preferred here>

      ## Decision made
      <Bulleted list>

      ## Open questions
      <Bulleted list; flag minority positions explicitly; unresolved disagreements are more important than resolved ones>

      ## Progress and action items
      <[x] Action that is already done
      [/] Action that is in progress (by person A, due by date B, if specified)
      [ ] Action that is to be done but not yet started>

  solo-private:                               # extends solo-restructure with private context and leverages an offline backend for privacy
    extends: solo-restructure
    backend: ollama                           # use local offline ollama model for sensitive content
    context_path:
      - "~/.asr2clip/context/private.md"      # include private info to improve reasoning
    extra: |
      This content is strictly private and must not be shared. Write "*Confidential - Do Not Share*" as both the first and last line of the memo.

  group-base:                                  # Note this is a "base" and is not intended to be used as a post-processor directly; The group-enhance was devised as the minimal post-processor for group discussion transcripts.
    backend: anthropic
    model: claude-sonnet-4-6
    template: bare
    prompt: |
      You are a professional meeting notetaker.
      Attached is a transcript from a recorded group discussion that contains multiple separate and individual speakers.
      Both the recording and the transcribing may have produced sub-standard quality which may make your work more demanding.
      Overcome any possible mistakes in the transcript and attempt to understand the true intent of each speaker.

  group-enhance:
    extends: group-base
    extra: |
      The content may be from a structured or freeform discussion, brainstorming or debating session, or something else.
      Produce an improved transcript that honors each speakers' original choice of words, structures and flow but fix misspellings and grammatical and transcription mistakes, reduce unnecessary words and repetition and otherwise improve the quality and legibility of the transcript.
      Output the enhanced transcript without any frontmatter or leading "meta" notes.
      Any significant interpretation uncertainties that have substantive impact on the information content can however be noted at the end after a separator line '\n---\n\n'.

  group-restructure:
    extends: group-base
    context_path:
      - "~/project_x/README.md"               # essential project information
      - "~/project_x/todo.md"                 # information about current status and ongoing tasks
    template: full
    prompt: |
      As output, produce a concise, structured, legible memo that promotes flow for the whole team.
      The memo should be very concise but still comprehensively contain all relevant information from the discussion, at least such as to remind participants of their contributions.
      The following provides a template. Omit sections that would have no clear content.

      # YYYY-MM-DD HH:SS Meeting on <Topic in Title Case>
      Tags: memo, <3-10 tags relevant to the content of the meeting>

      ## Summary
      <2-5 sentences describing the purpose, nature and content of the meeting overall>

      ## Key points
      <Bulleted list; Important to get all essential discussion topics and contributions covered; Chronological flow is preferred here>

      ## Decision made
      <Bulleted list>

      ## Open questions
      <Bulleted list; flag minority positions explicitly; unresolved disagreements are more important than resolved ones>

      ## Progress and action items
      <[x] Action that is already done
      [/] Action that is in progress (by person A, due by date B, if specified)
      [ ] Action that is to be done but not yet started>

  group-private:                              # extends group-restructure with confidential context and leverages an offline backend for privacy
    extends: group-restructure
    backend: ollama                           # use local offline ollama model for sensitive content
    context_path:
      - "~/project_x/confidential.md"         # include confidential info to improve reasoning
    extra: |
      This content is strictly private and must not be shared. Write "*Confidential - Do Not Share*" as both the first and last line of the memo.

## Which post-processor to apply automatically (none = disabled):
postprocessor_live: none                      # toggle / VAD / single live recording
postprocessor_file: none                      # -i file transcription

## ── Output templates ──────────────────────────────────────────────────────────
## Named templates controlling what gets copied to clipboard / written to -o FILE.
## Placeholders: {result} {transcript} {date} {datetime}
##               {prompt_name} {model} {backend} {duration_s}
output_templates:
  bare: "{result}"
  full: |
    {result}

    ---

    *Transcript from {duration_s:.0f}s recording post-processed at {datetime} with asr2clip ({backend}, {prompt_name}, {model})*

    ## Original transcript

    {transcript}

## ── Other parameters ──────────────────────────────────────────────────────────
# quiet: false                                # true = only output transcription and errors
# org_id:                                     # OpenAI organization ID (rarely needed)
#
# Maximum transcript characters copied as text to clipboard. When the transcript text
# exceeds this limit, the path to the transcript file is copied to the clipboard instead.
# 50 000 chars ≈ 1 hour of speech at 150 wpm & 5 chars per word (English audiobook rate).
# Modern clipboards (X11 INCR, Wayland, macOS NSPasteboard, Windows) have no OS-imposed
# limit — this is a pure usability heuristic. Set to 0 to always copy a file path instead
# (uses a temp file in /tmp when no -o FILE was given; wiped at reboot by OS policy).
# clipboard_max_chars: 50000
